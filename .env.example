# Supabase Configuration
# Get these values from your Supabase project settings
# https://app.supabase.com/project/[your-project-id]/settings/api

# Your Supabase project URL
EXPO_PUBLIC_SUPABASE_URL=https://[your-project-id].supabase.co

# Your Supabase anonymous key (PUBLIC, safe to expose in client code)
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Service role key (KEEP SECRET, never commit, only for backend)
# SUPABASE_SERVICE_ROLE_KEY=...

# Notes:
# - EXPO_PUBLIC_* prefix makes it available to Expo app
# - Do NOT commit actual keys; use .env.local for real values
# - Do NOT commit .env.local to git
# - Anonymous key (ANON_KEY) is PUBLIC and safe to use in client
# - Service role key must NEVER be exposed to client
