{
  "name": "fast-food",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && node scripts/write-healthz.mjs",
    "build:sanity": "npx tsc -p tsconfig.build.json",
    "typecheck:tier1": "npx tsc -p tsconfig.tier1.json",
    "db:migrate": "npx ts-node db/migrate.ts",
    "db:migrate:staging": "npx ts-node db/migrate.ts",
    "db:verify:staging": "npx ts-node scripts/db-verify-staging.ts",
    "sessions:prune": "npx ts-node scripts/prune-abandoned-sessions.ts",
    "metrics:prune": "npx ts-node scripts/metrics-prune.ts",
    "global-priors:refresh": "npx ts-node scripts/global-priors-refresh.ts",
    "sql:contract:gate": "node scripts/sql-contract-gate.js",
    "staging:healthcheck": "npx ts-node scripts/staging-healthcheck.ts",
    "smoke:staging": "npx ts-node scripts/smoke-staging.ts",
    "smoke:tier1:staging": "npx ts-node scripts/smoke-tier1-staging.ts",
    "auth:sanity": "npx ts-node scripts/auth-sanity.ts",
    "auth:sanity:require200": "npx ts-node scripts/auth-sanity-require200.ts",
    "auth:sanity:require401": "npx ts-node scripts/auth-sanity-require401.ts",
    "dogfood:report": "npx ts-node scripts/dogfood-report.ts",
    "deploy:record:lastgreen": "npx ts-node scripts/deploy-record-lastgreen.ts",
    "release:preflight": "npx ts-node scripts/release-preflight.ts",
    "signoff:tier1": "npx ts-node scripts/tier1-signoff.ts",
    "release:testflight": "eas build --profile production --platform ios --auto-submit",
    "lint": "eslint 'app/**/*.{ts,tsx}' 'components/**/*.{ts,tsx}' 'hooks/**/*.ts' 'lib/seeds/**/*.ts' 'lib/state/**/*.ts' 'lib/ui/**/*.ts' --ignore-pattern '**/__tests__/**' --ignore-pattern 'app/api/**' --ignore-pattern 'app/components/**' --ignore-pattern 'app/contexts/**' --ignore-pattern 'app/hooks/**' --max-warnings 0",
    "lint:tier1": "eslint 'app/_layout.tsx' 'app/tonight.tsx' 'app/deal.tsx' 'app/checklist/[recipeId].tsx' 'app/rescue/[mealId].tsx' 'app/api/decision-os/actor+api.ts' 'app/api/decision-os/sync/events+api.ts' 'app/api/decision-os/user-weights+api.ts' 'app/api/decision-os/global-priors+api.ts' 'lib/learning/**/*.ts' 'lib/decision-core/**/*.ts' 'lib/context/**/*.ts' 'lib/supabase/**/*.ts' 'scripts/global-priors-refresh.ts' 'db/migrate.ts' --ignore-pattern '**/__tests__/**' --max-warnings 0",
    "test": "jest",
    "test:tier1": "jest __tests__/context-signature.test.ts __tests__/decision-core-determinism.test.ts __tests__/learning-events-queue.test.ts __tests__/learning-weights-v1.test.ts __tests__/local-runtime-boundary.test.ts lib/decision-os/__tests__/migrate-logic.test.ts lib/decision-os/__tests__/migration-ordering.test.ts lib/decision-os/__tests__/auth-helper.test.ts --runInBand"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^14.0.2",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-navigation/native": "^6.1.18",
    "@supabase/supabase-js": "^2.45.4",
    "expo": "~52.0.0",
    "expo-blur": "~14.0.2",
    "expo-calendar": "~14.0.6",
    "expo-camera": "~16.0.18",
    "expo-constants": "~17.0.8",
    "expo-device": "~7.0.3",
    "expo-font": "~13.0.4",
    "expo-haptics": "~14.0.0",
    "expo-image": "~2.0.7",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.1",
    "expo-linking": "~7.0.5",
    "expo-location": "~18.0.10",
    "expo-notifications": "~0.29.14",
    "expo-router": "~4.0.17",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.3",
    "expo-web-browser": "~14.0.2",
    "lucide-react-native": "^0.563.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.7",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~3.16.1",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/jest": "^29.5.12",
    "@types/pg": "^8.16.0",
    "@types/react": "~18.3.12",
    "@types/react-test-renderer": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "react-test-renderer": "18.3.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },

  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "private": true,
  "optionalDependencies": {
    "pg": "^8.17.2",
    "pg-connection-string": "^2.10.1"
  }
}
